{
  "name": "pokemon-miniapp",
  "version": "1.0.0",
  "description": "Pokemon themed WeChat Mini Program with Vue3",
  "main": "app.js",
  "scripts": {
    "dev": "npm run dev:mp-weixin",
    "dev:mp-weixin": "uni -p mp-weixin",
    "build": "npm run build:mp-weixin",
    "build:mp-weixin": "uni build -p mp-weixin",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "compress-images": "node scripts/compress-images.mjs"
  },
  "dependencies": {
    "@dcloudio/uni-app": "^3.0.0-alpha-3090920230324001",
    "@dcloudio/uni-mp-weixin": "^3.0.0-alpha-3090920230324001",
    "axios": "^1.6.2",
    "pinia": "^2.1.7",
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.3.2",
    "@dcloudio/uni-cli-shared": "^3.0.0-alpha-3090920230324001",
    "@dcloudio/vite-plugin-uni": "^3.0.0-alpha-3090920230324001",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/ui": "^1.0.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^23.0.1",
    "less": "^4.2.0",
    "sharp": "^0.34.5",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^4.5.0",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vitest": "^1.0.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^1.8.22"
  }
}
