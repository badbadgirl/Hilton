    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dcloudio/uni-app": "^3.0.0-alpha-3090920230324001",
    "@dcloudio/uni-mp-weixin": "^3.0.0-alpha-3090920230324001",
    "axios": "^1.6.2",
    "pinia": "^2.1.7",
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.3.2",
    "@dcloudio/uni-cli-shared": "^3.0.0-alpha-3090920230324001",
    "@dcloudio/vite-plugin-uni": "^3.0.0-alpha-3090920230324001",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/ui": "^1.0.4",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^23.0.1",
    "less": "^4.2.0",
    "typescript": "^5.2.2",
    "vite": "^4.5.0",
    "vitest": "^1.0.4",
    "vue-tsc": "^1.8.22"
